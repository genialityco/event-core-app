{
  "cli": {
    "version": ">= 12.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "CLIENT": "ails-events",
        "EXPO_PUBLIC_CLIENT": "ails-events"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "CLIENT": "ails-events",
        "EXPO_PUBLIC_CLIENT": "ails-events"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "CLIENT": "ails-events",
        "EXPO_PUBLIC_CLIENT": "ails-events"
      }
    },
    "acho-development": {
      "extends": "development",
      "env": {
        "CLIENT": "acho",
        "EXPO_PUBLIC_CLIENT": "acho"
      }
    },
    "acho-preview": {
      "extends": "preview",
      "env": {
        "CLIENT": "acho",
        "EXPO_PUBLIC_CLIENT": "acho"
      }
    },
    "acho-production": {
      "extends": "production",
      "env": {
        "CLIENT": "acho",
        "EXPO_PUBLIC_CLIENT": "acho"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "TODO_AILS_APPLE_ID",
        "ascAppId": "TODO_AILS_ASC_APP_ID",
        "appleTeamId": "TODO_AILS_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "TODO_PATH_TO_AILS_SERVICE_ACCOUNT.json",
        "track": "production"
      }
    },
    "acho-production": {
      "ios": {
        "appleId": "recertificacion@acho.com.co",
        "ascAppId": "6736631927",
        "appleTeamId": "5WNKQXCLCD"
      },
      "android": {
        "serviceAccountKeyPath": "./achoapp-438923-7f30f65dff1b.json",
        "track": "production"
      }
    }
  }
}
